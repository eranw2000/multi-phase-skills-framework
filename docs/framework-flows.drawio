        <mxCell id="e_arch_prd2i" value="Path B (default)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;strokeColor=#0050b3;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="architect" target="prd2i">
