<mxfile host="app.diagrams.net" type="device">
  <diagram id="framework-flows" name="Framework skill flows">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="3000" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Multi-Phase Skills Framework, skill usage flows" style="text;html=1;fontStyle=1;fontSize=20;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="8" width="1300" height="30" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="Legend&#10;&#10;Green ellipse = start.  Blue rounded = skill / process step.  Rhombus = decision.&#10;Orange document = input / PRD artifact (a GitHub issue).  Yellow cylinder = artifact / data store (.md files, issues, code).&#10;Dashed border = optional step.  Purple rounded = external handoff (not bundled).&#10;&#10;Solid blue arrow = main flow.  Light blue arrow = produces artifact.  Gray dashed arrow = optional / warm-start / stress-test.&#10;Dark box and dark dashed arrow = GitHub (repo, issues, pull requests)." style="rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="48" width="900" height="210" as="geometry" />
        </mxCell>

        <mxCell id="intro" value="Two flows, one decision&#10;&#10;FULL PATH (multi-feature, unclear scope, compliance / numbered IDs, or unvalidated need):&#10;   /analyst to REQUIREMENTS.md, then /architect to SPEC.md, then /prd-to-issues, then /tdd.&#10;&#10;LIGHTWEIGHT PATH (one well-bounded feature whose shape is already clear):&#10;   /write-a-prd to a single PRD issue, then /tdd (or /prd-to-issues first if it is more than one slice).&#10;&#10;Both paths converge at /tdd and end with an external review + PR per the team's process.&#10;grill-me is optional and reusable: stress-test the idea or BRAINSTORM.md before picking a path,&#10;and re-run it on REQUIREMENTS.md or SPEC.md before the next step." style="rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="970" y="48" width="900" height="210" as="geometry" />
        </mxCell>

        <mxCell id="instr_file" value="instruction file&#10;(~/.claude/instructions/)&#10;project context, goal, repo, stack" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="30" y="278" width="220" height="64" as="geometry" />
        </mxCell>
        <mxCell id="instruct" value="/instruct&#10;loads the instruction file,&#10;auto-enters Plan mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="360" width="220" height="66" as="geometry" />
        </mxCell>
        <mxCell id="start" value="New work to plan&#10;(brainstorm in Plan mode)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="200" height="68" as="geometry" />
        </mxCell>
        <mxCell id="brainstorm" value="/capture-brainstorming&#10;(optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="35" y="566" width="210" height="56" as="geometry" />
        </mxCell>
        <mxCell id="bmd" value="BRAINSTORM.md" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="50" y="652" width="175" height="72" as="geometry" />
        </mxCell>
        <mxCell id="handoff_note" value="Session handoff&#10;If the Context Window gets heavy (> ~400K),&#10;start a fresh session and re-upload&#10;BRAINSTORM.md so the next session&#10;(e.g. /analyst) warm-starts." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="824" width="300" height="110" as="geometry" />
        </mxCell>

        <mxCell id="grillme" value="/grill-me (optional, reusable)&#10;stress-test the idea or BRAINSTORM.md&#10;before picking a path" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="452" width="260" height="84" as="geometry" />
        </mxCell>

        <mxCell id="gate" value="Single, well-bounded feature?&#10;Scope clear, need validated?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe599;strokeColor=#d6b656;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="600" width="250" height="110" as="geometry" />
        </mxCell>

        <mxCell id="wprd" value="/write-a-prd" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="330" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prd" value="PRD = one GitHub issue&#10;(PRD.md as fallback)&#10;PRD-only, never REQUIREMENTS.md" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="1000" y="318" width="210" height="86" as="geometry" />
        </mxCell>
        <mxCell id="sliceq" value="More than one&#10;vertical slice?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1290" y="318" width="200" height="96" as="geometry" />
        </mxCell>

        <mxCell id="analyst" value="/analyst" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="700" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="reqmd" value="REQUIREMENTS.md" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="730" y="800" width="170" height="74" as="geometry" />
        </mxCell>
        <mxCell id="note_grillreq" value="optional: re-run /grill-me on REQUIREMENTS.md" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="700" y="884" width="260" height="28" as="geometry" />
        </mxCell>

        <mxCell id="architect" value="/architect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="700" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="specmd" value="SPEC.md" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1180" y="800" width="120" height="74" as="geometry" />
        </mxCell>
        <mxCell id="archdrawio" value="architecture.drawio" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1320" y="800" width="150" height="74" as="geometry" />
        </mxCell>
        <mxCell id="note_grillspec" value="optional: re-run /grill-me on SPEC.md" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1180" y="884" width="290" height="28" as="geometry" />
        </mxCell>
        <mxCell id="patha" value="architect sub-paths:&#10;Path B (default) = /prd-to-issues.&#10;Path A (opt-in) = OpenSpec change via /opsx:propose." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;align=left;spacingLeft=8;spacingTop=4;verticalAlign=top;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1200" y="610" width="380" height="66" as="geometry" />
        </mxCell>

        <mxCell id="prd2i" value="/prd-to-issues&#10;tracer-bullet vertical slices&#10;(walking skeleton first)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1680" y="690" width="220" height="86" as="geometry" />
        </mxCell>
        <mxCell id="issues" value="Vertical-slice issues" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1705" y="810" width="175" height="74" as="geometry" />
        </mxCell>

        <mxCell id="tdd" value="/tdd per issue&#10;(red-green-refactor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="2050" y="500" width="200" height="92" as="geometry" />
        </mxCell>
        <mxCell id="code" value="code" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=12;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="2090" y="640" width="120" height="74" as="geometry" />
        </mxCell>
        <mxCell id="handoff" value="Hand off for review + PR&#10;(external, per team process;&#10;not bundled)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="2320" y="505" width="220" height="82" as="geometry" />
        </mxCell>

        <mxCell id="supbox" value="Supporting skills (used across the chain, not in the main line)" style="rounded=0;fillColor=#fafafa;strokeColor=#999999;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;dashed=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="1020" width="1410" height="96" as="geometry" />
        </mxCell>
        <mxCell id="sup_init" value="/init-project" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="supbox">
          <mxGeometry x="20" y="42" width="250" height="44" as="geometry" />
        </mxCell>
        <mxCell id="sup_new" value="/new-session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="supbox">
          <mxGeometry x="295" y="42" width="250" height="44" as="geometry" />
        </mxCell>
        <mxCell id="sup_todo" value="/todo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="supbox">
          <mxGeometry x="570" y="42" width="250" height="44" as="geometry" />
        </mxCell>
        <mxCell id="sup_save" value="/save-context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="supbox">
          <mxGeometry x="845" y="42" width="250" height="44" as="geometry" />
        </mxCell>
        <mxCell id="sup_close" value="/close-session" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="supbox">
          <mxGeometry x="1120" y="42" width="250" height="44" as="geometry" />
        </mxCell>

        <mxCell id="note_init" value="/init-project documents the project once and writes CLAUDE.md&#10;(for a source-code repo, use the built-in /init instead). It does not&#10;implement. /instruct (entry stage) performs the work." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;dashed=1;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="30" y="1020" width="360" height="96" as="geometry" />
        </mxCell>

        <mxCell id="github" value="GitHub" style="rounded=0;fillColor=#fafafa;strokeColor=#24292e;strokeWidth=2;fontStyle=1;fontSize=14;verticalAlign=top;align=left;spacingLeft=12;spacingTop=8;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="2660" y="300" width="340" height="540" as="geometry" />
        </mxCell>
        <mxCell id="gh_repo" value="Repository&#10;(created first if greenfield;&#10;issues and PRs need a home)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#24292e;" vertex="1" parent="github">
          <mxGeometry x="20" y="46" width="300" height="120" as="geometry" />
        </mxCell>
        <mxCell id="gh_issues" value="Issues&#10;- PRD (lightweight path)&#10;- vertical-slice tickets (/prd-to-issues)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#24292e;" vertex="1" parent="github">
          <mxGeometry x="20" y="190" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="gh_pr" value="Pull request&#10;- review per team process&#10;- merge to main" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#24292e;" vertex="1" parent="github">
          <mxGeometry x="20" y="364" width="300" height="150" as="geometry" />
        </mxCell>

        <mxCell id="e_instrfile_instruct" value="reads" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=11;" edge="1" parent="1" source="instr_file" target="instruct">
