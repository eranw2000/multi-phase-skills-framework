        <mxCell id="e_bmd_analyst" value="warm-starts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;dashed=1;strokeColor=#999999;fontSize=11;" edge="1" parent="1" source="bmd" target="analyst">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_start_grill" value="optional" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;dashed=1;strokeColor=#999999;fontSize=11;" edge="1" parent="1" source="start" target="grillme">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_grill_gate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="grillme" target="gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_start_gate" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;strokeColor=#0050b3;strokeWidth=2;" edge="1" parent="1" source="start" target="gate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_gate_wprd" value="YES: single feature" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;strokeColor=#0050b3;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="gate" target="wprd">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_gate_analyst" value="NO: multi-feature, unclear scope, compliance, or unvalidated" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;strokeColor=#0050b3;strokeWidth=2;fontSize=11;" edge="1" parent="1" source="gate" target="analyst">
          <mxGeometry relative="1" as="geometry" />
