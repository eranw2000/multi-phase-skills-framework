        <mxCell id="e_prd2i_issues" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;" edge="1" parent="1" source="prd2i" target="issues">
