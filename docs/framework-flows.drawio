        <mxCell id="e_wprd_prd" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;html=1;strokeColor=#0050b3;strokeWidth=2;" edge="1" parent="1" source="wprd" target="prd">
          <mxGeometry relative="1" as="geometry" />
